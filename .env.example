# =============================================================================
# MedClaim — Environment Variables
# Copy to .env and fill in your API keys:  cp .env.example .env
# =============================================================================

# --- LLM Providers ---
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- Vector Database (Qdrant Cloud) ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Persistence (Supabase) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLMOps (LangSmith) ---
# Get your API key from https://smith.langchain.com/settings
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=medclaim-dev
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"

# --- Task Queue (Upstash Redis) ---
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- Notifications (Resend) ---
RESEND_API_KEY=

# --- EHR Integration (HAPI FHIR) ---
HAPI_FHIR_URL=http://localhost:8080/fhir

# --- Voice AI (Optional — falls back to Coqui if not set) ---
ELEVEN_LABS_API_KEY=

# --- Application Configuration ---
APP_ENV=development
MARKET=US
LOG_LEVEL=DEBUG
